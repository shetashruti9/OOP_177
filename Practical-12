class VolumeCalculator {

    public double calculateVolume(double side) {
        return side * side * side;
    }

    public double calculateVolume(double length, double width, double height) {
        return length * width * height;
    }

    public double calculateVolume(float radius) {
        return (4.0 / 3.0) * Math.PI * radius * radius * radius;
    }

    public static void main(String[] args) {
        VolumeCalculator v = new VolumeCalculator();

        double cube = v.calculateVolume(3);
        double rectangularCube = v.calculateVolume(4, 5, 6);
        double sphere = v.calculateVolume(2.5f);

        System.out.println("Cube Volume: " + cube);
        System.out.println("Rectangular Cube Volume: " + rectangularCube);
        System.out.println("Sphere Volume: " + sphere);
    }
}
