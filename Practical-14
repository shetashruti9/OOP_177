class BankAccount {
    int accountNumber;
    String accountHolderName;
    double balance;

    public void openAccount(int accNo, String name, double bal) {
        accountNumber = accNo;
        accountHolderName = name;
        balance = bal;
    }

    public void deposit(double amount) {
        balance += amount;
    }

    public void withdraw(double amount) {
        if (amount <= balance) {
            balance -= amount;
        } else {
            System.out.println("Insufficient balance");
        }
    }

    public void checkBalance() {
        System.out.println("Balance: " + balance);
    }
}

class SavingAccount extends BankAccount {
    double interestRate = 4.0;

    public double calculateInterest() {
        return (balance * interestRate) / 100;
    }
}

class FixedDepositAccount extends BankAccount {
    double rate = 6.5;
    int time = 2;

    public double maturityAmount() {
        return balance + (balance * rate * time) / 100;
    }
}

public class Main {
    public static void main(String[] args) {
        SavingAccount sa = new SavingAccount();
        sa.openAccount(101, "Rahul", 10000);
        sa.deposit(2000);
        sa.withdraw(1500);
        sa.checkBalance();
        System.out.println("Interest: " + sa.calculateInterest());

        System.out.println();

        FixedDepositAccount fd = new FixedDepositAccount();
        fd.openAccount(102, "Priya", 20000);
        fd.checkBalance();
        System.out.println("Maturity Amount: " + fd.maturityAmount());
    }
}
